{
  "schemaVersion": 1,
  "id": "uncharted_upgrades",
  "version": "${version}",
  "name": "Uncharted Upgrades",
  "description": "Standalone tiered storage, furnaces, and upgrade and conversion kits for Uncharted Odyssey.",
  "authors": [
    "New College Worcester"
  ],
  "license": "MIT",
  "icon": "assets/uncharted_upgrades/textures/item/netherite_conversion_kit.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "uk.co.newcollegeworcester.uo.upgradekits.UoUpgradeKits"
    ],
    "client": [
      "uk.co.newcollegeworcester.uo.upgradekits.UoUpgradeKitsClient"
    ],
    "fabric-datagen": [
      "uk.co.newcollegeworcester.uo.upgradekits.datagen.UoDataGenerator"
    ],
    "rei_client": [
      "uk.co.newcollegeworcester.uo.upgradekits.UoReiClientCompat"
    ]
  },
  "mixins": [
    "uncharted_upgrades.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
